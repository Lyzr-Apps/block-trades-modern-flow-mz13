      "description": "Active risk alerts"
    },
    "trends": {
      "type": "object",
      "properties": {
        "completion_trend": { "type": "string", "description": "improving, stable, declining" },
        "sentiment_trend": { "type": "string", "description": "improving, stable, declining" },
        "velocity_trend": { "type": "string", "description": "improving, stable, declining" }
      },
      "required": ["completion_trend", "sentiment_trend", "velocity_trend"],
      "description": "Week-over-week trends"
    }
  }
